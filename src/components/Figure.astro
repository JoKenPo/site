---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: "sm" | "md" | "lg" | "xl" | "full";
}

const { src, alt, caption, size = "lg" } = Astro.props;

const sizeMap = {
  sm: "max-w-sm",
  md: "max-w-md",
  lg: "max-w-2xl",
  xl: "max-w-4xl",
  full: "max-w-full",
};

const maxWidthClass = sizeMap[size] || sizeMap.lg;
---

<figure
  class={`my-6 flex flex-col items-center w-full ${maxWidthClass} mx-auto`}
>
  <img
    src={src}
    alt={alt}
    class="w-full rounded-lg shadow-md border border-site-border dark:border-site-border-dark"
  />
  {
    caption && (
      <figcaption class="mt-1 text-sm text-site-text/70 dark:text-site-text-dark/25 text-center italic font-serif w-full px-2">
        {caption}
      </figcaption>
    )
  }
</figure>
