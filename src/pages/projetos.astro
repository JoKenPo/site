---
import Base from '../layouts/Base.astro';
---

<Base title="Projetos · edu.dev">
  <h1>Projetos</h1>
  <p class="text-gray-500 dark:text-gray-400 mb-10">Coisas que construí ou estou construindo.</p>

  <div class="flex flex-col gap-8">
    <div class="p-6 bg-gray-50 dark:bg-[#1a1a1a] border border-gray-200 dark:border-gray-800 rounded-lg">
      <h2 class="text-xl font-bold mb-2 border-none pb-0"><a href="#" class="no-underline text-gray-900 dark:text-gray-100 hover:text-blue-700 dark:hover:text-brand">ZeroClaw Home Lab</a></h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Setup de home lab rodando no Raspberry Pi 3 com Docker, automações e serviços self-hosted.</p>
      <div class="flex gap-2">
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">Docker</span>
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">Raspberry Pi</span>
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">Linux</span>
      </div>
    </div>

    <div class="p-6 bg-gray-50 dark:bg-[#1a1a1a] border border-gray-200 dark:border-gray-800 rounded-lg">
      <h2 class="text-xl font-bold mb-2 border-none pb-0"><a href="#" class="no-underline text-gray-900 dark:text-gray-100 hover:text-blue-700 dark:hover:text-brand">ESP32 Automação</a></h2>
      <p class="text-gray-600 dark:text-gray-400 mb-4">Projetos de automação residencial com ESP32 e sensores.</p>
      <div class="flex gap-2">
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">ESP32</span>
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">IoT</span>
        <span class="bg-white dark:bg-[#111] border border-gray-200 dark:border-gray-700 px-2 py-1 rounded text-sm text-gray-500 dark:text-gray-400">C++</span>
      </div>
    </div>
  </div>
</Base>
